// WebBot data model.
//
// A user owns many workflows. A workflow is a graph of nodes and edges — each
// node and each edge is its own row (not a JSON blob), so they can be queried,
// indexed, and validated independently. Nodes/edges carry both a workflowId and
// a userId foreign key (userId is denormalised onto them for fast, safe
// ownership checks without a join back through Workflow).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  email        String     @unique
  // bcrypt hash — the per-user salt is embedded in the hash string itself.
  passwordHash String
  role         Role       @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  workflows    Workflow[]
  nodes        Node[]
  edges        Edge[]

  @@map("users")
}

model Workflow {
  id        String        @id @default(uuid())
  name      String
  viewport  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  nodes     Node[]
  edges     Edge[]
  runs      WorkflowRun[]

  @@index([userId])
  @@map("workflows")
}

model Node {
  id        String   @id @default(uuid())
  // The client-side node id (e.g. "n1783_4"); unique within a workflow. Edges
  // reference nodes by this key, matching the graph the editor/extension use.
  key       String
  type      String
  positionX Float    @default(0)
  positionY Float    @default(0)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workflowId, key])
  @@index([workflowId])
  @@index([userId])
  @@map("nodes")
}

model Edge {
  id            String  @id @default(uuid())
  key           String
  source        String
  target        String
  sourceHandle  String?
  targetHandle  String?

  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workflowId, key])
  @@index([workflowId])
  @@map("edges")
}

model WorkflowRun {
  id         String   @id @default(uuid())
  ok         Boolean
  result     Json
  createdAt  DateTime @default(now())

  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("workflow_runs")
}
