{
  "manifest_version": 3,
  "name": "WebBot Runner",
  "version": "0.2.0",
  "description": "Run WebBot workflows in your own browser, on your logged-in sessions.",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WebBot Runner"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "webbot-runner@example.com"
    }
  }
}
